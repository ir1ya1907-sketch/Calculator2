<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" Height="200" Width="300">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="InputA" Width="100" 
                     PreviewTextInput="NumberValidationTextBox"
                     HorizontalAlignment="Left" Margin="0,0,10,0"/>
            <TextBox x:Name="InputB" Width="100" 
                     PreviewTextInput="NumberValidationTextBox"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
            <Button Content="+" Width="50" Tag="+" Click="OnOperateClick" Margin="5"/>
            <Button Content="-" Width="50" Tag="-" Click="OnOperateClick" Margin="5"/>
            <Button Content="*" Width="50" Tag="*" Click="OnOperateClick" Margin="5"/>
            <Button Content="/" Width="50" Tag="/" Click="OnOperateClick" Margin="5"/>
        </StackPanel>

        <Label x:Name="ResultLabel" Grid.Row="2" FontSize="16" HorizontalAlignment="Center" />
    </Grid>
</Window>